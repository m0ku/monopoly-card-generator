<svg width="{{ width }}" height="{{ height }}" viewBox="0 0 {{ width }} {{ height }}" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
    <style>
        @font-face {
            font-family: 'Monopoly';
            src: url(data:font/woff2;base64,{{ font_b64 }}) format('woff2');
        }
        .card-title { font-family: 'sans-serif'; font-size: {{ title_size }}px; font-weight: bold; }
        .card-text { font-family: 'sans-serif'; font-size: {{ font_size }}px; font-weight: bold; }
    </style>

    <!-- Hintergrund -->
    <rect width="100%" height="100%" fill="{{ color }}" stroke="none" stroke-width="2"/>
    
    <!-- Title -->
    <text x="45%" y="30%" text-anchor="left" class="card-title">EREIGNISKARTE</text>

    <!-- Bild -->
    <image x="-30%" y="5%" width="100%" height="100%" href="data:image/svg+xml;base64,{{ img_b64 }}" />

    <!-- Text-Umrechnung mit TSPAN -->
    <text x="50%" y="50%" text-anchor="middle" class="card-text">
        {% for line in lines %}
            <tspan x="65%" dy="{{ '0' if loop.first else '1.2em' }}">{{ line }}</tspan>
        {% endfor %}
    </text>
</svg>