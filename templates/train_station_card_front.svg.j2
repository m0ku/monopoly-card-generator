<svg width="{{ width }}" height="{{ height }}" viewBox="0 0 {{ width }} {{ height }}" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
    <style>
        @font-face {
            font-family: 'Monopoly';
            src: url(data:font/woff2;base64,{{ font_b64 }}) format('woff2');
        }
        .card-title { font-family: 'sans-serif'; font-size: {{ title_size }}px; font-weight: bold; }
        .card-text-bold { font-family: 'sans-serif'; font-size: {{ font_size }}px; font-weight: bold; }
        .card-text { font-family: 'sans-serif'; font-size: {{ font_size }}px;}
        .card-text-small { font-family: 'sans-serif'; font-size: {{ font_size - 1 }}px;}
    </style>

    <!-- 1. Äußerer Kartenrand -->
    <rect width="100%" height="100%" fill="white" stroke="none" stroke-width="2"/>
    
    <!-- 2. Innerer Rahmen -->
    <!-- rect x="{{margin}}" y="{{margin}}" width="{{inner_width}}" height="{{inner_height}}" fill="none" stroke="black" stroke-width="1"/ -->
    
    <!-- Bild -->
    <image x="28%" y="-2%" width="45%" height="45%" href="data:image/svg+xml;base64,{{ img_b64 }}" />

    <!-- Titel -->
    <text x="50%" y="{{title_y}}" text-anchor="middle" class="card-text-bold" fill="black" style="text-transform: uppercase;">Besitzrechtkarte</text>
    <text x="50%" y="{{title_y + 35}}" text-anchor="middle" class="card-title" fill="black" style="text-transform: uppercase;">{{title}}</text>
    
    <!-- Mietentabelle -->
    <g transform="translate({{margin + 15}}, {{rect_y + header_h + 35}})" class="card-text-bold" font-size="13">
        <line x1="0%" y1="0" x2="84%" y2="0" style="stroke:black;stroke-width:1.5"/>
        <text x="0" y="35">Miete</text> <text x="{{width - 2*margin - 30}}" y="35" text-anchor="end">{{price}}€</text>
        <text x="0" y="55">Wenn man 2 Bahnhöfe besitzt</text> <text x="{{width - 2*margin - 30}}" y="55" text-anchor="end">{{price*2}}€</text>
        <text x="0" y="75">Wenn man 3 Bahnhöfe besitzt</text> <text x="{{width - 2*margin - 30}}" y="75" text-anchor="end">{{price*4}}€</text>
        <text x="0" y="95">Wenn man 4 Bahnhöfe besitzt</text> <text x="{{width - 2*margin - 30}}" y="95" text-anchor="end">{{price*8}}€</text>
    </g>

</svg>