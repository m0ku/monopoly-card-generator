<svg width="{{ width }}" height="{{ height }}" viewBox="0 0 {{ width }} {{ height }}" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
    <style>
        @font-face {
            font-family: 'Monopoly';
            src: url(data:font/woff2;base64,{{ font_b64 }}) format('woff2');
        }
        .card-title { font-family: 'sans-serif'; font-size: {{ title_size }}px; font-weight: bold; stroke: black; stroke-width: 1.5; }
        .card-text { font-family: 'sans-serif'; font-size: {{ font_size }}px; font-weight: bold; }
    </style>

    <defs>
    <!-- Define the pattern and its repeating dimensions -->
    <pattern id="my-pattern" width="350" height="350" patternUnits="userSpaceOnUse" patternTransform="rotate(30)">
        <!-- Background image -->
        <image x="0" y="0" width="100%" height="100%" href="data:image/svg+xml;base64,{{ img_b64 }}"></image>
    </pattern>
    </defs>

    <!-- Hintergrund -->
    <rect width="100%" height="100%" fill="{{ color }}" stroke="none" stroke-width="2"/>
    <!-- Background image -->
    <rect width="100%" height="100%" fill="url(#my-pattern)"/>
    
    <!-- Title -->
    <text x="50%" y="50%" text-anchor="middle" class="card-title">EREIGNISKARTE</text>
</svg>