<svg width="{{ width }}" height="{{ height }}" viewBox="0 0 {{ width }} {{ height }}" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
    <style>
        @font-face {
            font-family: 'Monopoly';
            src: url(data:font/woff2;base64,{{ font_b64 }}) format('woff2');
        }
        .card-title { font-family: 'sans-serif'; font-size: {{ title_size }}px; font-weight: bold; }
        .card-text-bold { font-family: 'sans-serif'; font-size: {{ font_size }}px; font-weight: bold; }
        .card-text { font-family: 'sans-serif'; font-size: {{ font_size }}px;}
        .card-text-small { font-family: 'sans-serif'; font-size: {{ font_size - 1 }}px;}
        .card-price { font-family: 'sans-serif'; font-size: {{ title_size }}px; font-weight: bold; }
    </style>

    <!-- 1. Äußerer Kartenrand -->
    <rect width="100%" height="100%" fill="white" stroke="none" stroke-width="2"/>
    
    <!-- 2. Schwebendes rotes Farbfeld (mit Abstand zum Rahmen) -->
    <rect x="{{rect_x}}" y="{{rect_y}}" width="{{rect_w}}" height="{{header_h}}" fill="red"/>
    
    <!-- Titel -->
    <text x="50%" y="20%" text-anchor="middle" class="card-title" fill="white" style="text-transform: uppercase;">
        {{title}}
    </text>

    <!-- Hypothekenbrief -->
    <text x="50%" y="33%" text-anchor="middle" class="card-text" fill="white" style="text-transform: uppercase;">
        Hypothekenbrief
    </text>

    <!-- Wert der Hypothek -->
    <text x="50%" y="40%" text-anchor="middle" class="card-price" fill="white" style="text-transform: uppercase;">
        {{rents[1]}}€
    </text>

    <!-- Auflösung -->
    <text x="50%" y="53%" text-anchor="middle" class="card-text" fill="white" style="text-transform: uppercase;">
        Hypothek auflösen für
    </text>

    <!-- Hypothekenverkaufswert -->
    <text x="50%" y="60%" text-anchor="middle" class="card-price" fill="white" style="text-transform: uppercase;">
        {% set selling_price = math.floor((rents[1] | int )*1.1) %}
        {{ selling_price }}€
    </text>

    <text x="0" y="75%" class="card-text-small" fill="white" >
        <tspan x="50%" dy="0" text-anchor="middle">Die Karte muss auf diese Seite</tspan>
        <tspan x="50%" dy="1.2em" text-anchor="middle">umgedreht werden, wenn</tspan>
        <tspan x="50%" dy="1.2em" text-anchor="middle" >das Grundstück belastet ist.</tspan>
    </text>

</svg>